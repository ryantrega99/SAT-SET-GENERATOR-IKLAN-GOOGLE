{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and usage limits.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "isPro": { "type": "boolean" },
        "generationCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "isPro", "generationCount"]
    },
    "Campaign": {
      "title": "Ad Campaign",
      "description": "Saved ad campaigns generated by the user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "businessName": { "type": "string" },
        "description": { "type": "string" },
        "tone": { "type": "string" },
        "result": { "type": "object" },
        "timestamp": { "type": "number" }
      },
      "required": ["userId", "businessName", "result", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile and limit tracking."
    },
    "/campaigns/{campaignId}": {
      "schema": "Campaign",
      "description": "User generated campaigns."
    }
  }
}
